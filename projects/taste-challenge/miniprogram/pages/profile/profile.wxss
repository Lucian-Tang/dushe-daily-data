.page-profile { padding: 32rpx; min-height: 100vh; background: #0A0A12; }
.profile-hero { display: flex; flex-direction: column; align-items: center; padding: 48rpx 0; }
.profile-emoji { font-size: 96rpx; }
.profile-rank { font-size: 40rpx; font-weight: 700; margin-top: 12rpx; }
.profile-score { font-size: 26rpx; color: #666; margin-top: 8rpx; }
.section { margin: 24rpx 0; }
.section-title { font-size: 28rpx; color: #666; margin-bottom: 16rpx; }
.history-item { display: flex; justify-content: space-between; padding: 16rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.04); }
.h-date { font-size: 26rpx; color: #888; }
.h-score { font-size: 26rpx; font-weight: 600; }
.empty { text-align: center; padding: 40rpx; }
.empty text { font-size: 24rpx; color: #555; }
.brand-footer { text-align: center; padding: 48rpx 0; }
.brand-footer text { font-size: 22rpx; color: #333; }
