.page-result { min-height: 100vh; background: #0A0A12; display: flex; flex-direction: column; align-items: center; padding: 48rpx 32rpx; }

/* 得分环 */
.score-hero { text-align: center; margin: 20rpx 0; }
.score-circle { width: 200rpx; height: 200rpx; border-radius: 50%; background: linear-gradient(135deg, #FFD700, #E85D75); display: flex; flex-direction: column; align-items: center; justify-content: center; margin: 0 auto; }
.score-num { font-size: 64rpx; font-weight: 800; color: #0A0A12; line-height: 1; }
.score-unit { font-size: 24rpx; color: #0A0A12; }
.score-detail { margin-top: 24rpx; }
.detail-row { display: block; font-size: 26rpx; color: #888; margin-bottom: 6rpx; }

/* 段位 */
.rank-banner { display: flex; align-items: center; padding: 32rpx 48rpx; background: rgba(255,255,255,0.03); border-radius: 20rpx; margin: 32rpx 0; width: 100%; }
.rank-emoji { font-size: 64rpx; }
.rank-info { margin-left: 20rpx; }
.rank-title { font-size: 24rpx; color: #666; display: block; }
.rank-name { font-size: 36rpx; color: #FFD700; font-weight: 600; display: block; margin-top: 4rpx; }
.rank-praise { font-size: 26rpx; color: #aaa; line-height: 1.5; margin-top: 8rpx; display: block; }
.rank-tag-row { margin-top: 10rpx; }
.rank-tag { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 20rpx; }
.rank-tag.praise { background: rgba(0,212,170,0.12); color: #00D4AA; }
.rank-tag.challenge { background: rgba(232,93,117,0.12); color: #E85D75; }
.rank-tag.encourage { background: rgba(255,215,0,0.12); color: #FFD700; }

/* 操作 */
.actions { width: 100%; margin-top: 20rpx; }
button { width: 100%; padding: 24rpx; border-radius: 16rpx; font-size: 30rpx; margin-bottom: 16rpx; border: none; }
.btn-primary { background: linear-gradient(135deg, #FFD700, #FFA500); color: #0A0A12; font-weight: 700; }
.btn-secondary { background: rgba(255,255,255,0.05); color: #E8E8E8; border: 1rpx solid rgba(255,255,255,0.08) !important; }

.share-canvas { position: fixed; left: -9999rpx; }

.brand-stamp { margin-top: 48rpx; padding: 20rpx 0; }
.brand-stamp text { font-size: 22rpx; color: #333; }
