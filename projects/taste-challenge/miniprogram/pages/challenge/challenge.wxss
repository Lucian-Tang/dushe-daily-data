.page-challenge { min-height: 100vh; background: #0A0A12; padding: 32rpx; }
.challenge-bar { display: flex; justify-content: space-between; padding: 20rpx 0; }
.bar-mode { font-size: 26rpx; color: #FFD700; }
.bar-progress { font-size: 24rpx; color: #888; }

.q-card { background: #111122; border-radius: 20rpx; padding: 32rpx; margin-top: 24rpx; }
.q-tag { display: inline-block; padding: 6rpx 20rpx; border-radius: 20rpx; font-size: 22rpx; color: #fff; margin-bottom: 20rpx; }
.q-text { font-size: 30rpx; color: #E8E8E8; line-height: 1.6; display: block; margin-bottom: 24rpx; }

.q-image-wrap { margin-bottom: 24rpx; border-radius: 12rpx; overflow: hidden; background: #0A0A12; }
.q-image { width: 100%; height: 400rpx; }

.options { margin-top: 16rpx; }
.option-item { display: flex; align-items: flex-start; padding: 24rpx; margin-bottom: 16rpx; background: rgba(255,255,255,0.04); border-radius: 12rpx; border: 2rpx solid transparent; }
.option-item:active { background: rgba(255,215,0,0.08); }
.option-item.correct { border-color: #00D4AA; background: rgba(0,212,170,0.08); }
.option-item.wrong { border-color: #E85D75; background: rgba(232,93,117,0.08); }
.opt-letter { font-size: 28rpx; color: #FFD700; margin-right: 12rpx; font-weight: 600; }
.opt-text { flex: 1; font-size: 26rpx; color: #ccc; line-height: 1.5; }

.explanation { background: #111122; border-radius: 16rpx; padding: 24rpx; margin-top: 24rpx; }
.exp-title { font-size: 28rpx; color: #FFD700; display: block; margin-bottom: 8rpx; }
.exp-text { font-size: 24rpx; color: #888; line-height: 1.6; }

.challenge-actions { margin-top: 32rpx; display: flex; justify-content: center; }
.btn-primary { background: linear-gradient(135deg, #FFD700, #FFA500); color: #0A0A12; border: none; border-radius: 48rpx; padding: 24rpx 64rpx; font-size: 30rpx; font-weight: 600; }

.loading { display: flex; align-items: center; justify-content: center; height: 80vh; }
.loading text { font-size: 28rpx; color: #555; }
